# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ---------------------------------------------------------------------------
# PostgreSQL (sharded)
# ---------------------------------------------------------------------------
# The app connects to N separate PostgreSQL databases (the "shards").
# All shards live on the same PostgreSQL server for local dev, but in
# production each could point to a different host.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# Shard databases are named "<DB_NAME_PREFIX>_0", "<DB_NAME_PREFIX>_1", ...
DB_NAME_PREFIX=orders_shard
SHARD_COUNT=4

# Optional: override per-shard connection strings instead of the pattern
# above (comma separated, must match SHARD_COUNT). Leave empty to use the
# host/prefix pattern.
# SHARD_URLS=postgres://user:pass@host0:5432/shard0,postgres://user:pass@host1:5432/shard1

# ---------------------------------------------------------------------------
# Google Cloud Storage (Application Default Credentials)
# ---------------------------------------------------------------------------
# Do NOT put a service-account key path here for local dev.
# Run `gcloud auth application-default login` once, and the client
# library will pick up the credentials automatically.
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-gcs-bucket-name

# Only set this if you are intentionally using a service-account key file
# for local testing (NEVER commit the key file, NEVER set this in prod).
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/key.json

# ---------------------------------------------------------------------------
# Ingestion tuning
# ---------------------------------------------------------------------------
BATCH_SIZE=500
UPLOAD_DIR=uploads
